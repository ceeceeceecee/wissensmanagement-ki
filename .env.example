# Umgebungseinstellungen für kommunales Wissensmanagement
# Kopieren Sie diese Datei als .env und passen Sie die Werte an.

# Ollama KI-Server (muss lokal erreichbar sein)
OLLAMA_HOST=http://localhost:11434

# Name des verwendeten KI-Modells
MODEL_NAME=llama3

# PostgreSQL Datenbankverbindung
POSTGRES_URL=postgresql://wissens:wissens@localhost:5432/wissensmanagement

# Pfad für hochgeladene Dokumente
DATA_PATH=./data

# Persistenz-Verzeichnis für ChromaDB
CHROMA_PATH=./.chroma

# Protokollierungsstufe (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
